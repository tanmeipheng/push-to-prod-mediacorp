ANTHROPIC_API_KEY=sk-ant-xxx
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=tanmeipheng/push-to-prod-mediacorp
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
# Preferred: Slack member ID (for an actual mention), e.g. U12345678.
# Plain @username is also supported, but may render as text rather than a real mention.
SLACK_CODE_OWNER=U12345678
MOCK_SERVER_URL=http://localhost:8429

# Jira Cloud credentials for automatic incident creation + stage transitions
JIRA_BOARD_URL=https://your-domain.atlassian.net/jira/software/projects/PTP/boards/1
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=atlassian-api-token
# Optional overrides if you do not want them derived from JIRA_BOARD_URL
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_PROJECT_KEY=PTP
JIRA_ISSUE_TYPE=Task
JIRA_STATUS_TODO=TO DO
JIRA_STATUS_IN_PROGRESS=IN PROGRESS
JIRA_STATUS_IN_REVIEW=IN REVIEW

# Set to "true" to push branch + open PR on GitHub (default: local only)
TFAH_PUSH_TO_REMOTE=false
# Base branch for PRs (default: main)
TFAH_BASE_BRANCH=main
